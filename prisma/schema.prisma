datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          Int         @id @default(autoincrement())
  category    String
  name        String
  description String
  price       Float // Usando Float conforme sua preferência
  image       String
  orderItems  OrderItem[] // Habilita a relação inversa
}

model Customer {
  id           Int      @id @default(autoincrement())
  fullName     String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  mobile       String   @db.VarChar(255)
  document     String   @db.VarChar(255)
  zipCode      String   @db.VarChar(255)
  street       String   @db.VarChar(255)
  number       String   @db.VarChar(255)
  complement   String?  @db.VarChar(255)
  neighborhood String   @db.VarChar(255)
  city         String   @db.VarChar(255)
  state        String   @db.Char(2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]  // Habilita a relação inversa
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}

model Order {
  id            Int         @id @default(autoincrement())
  status        OrderStatus @default(PENDING)
  total         Decimal     @db.Decimal(10, 2)
  transactionId String?     @db.VarChar(255)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customer      Customer    @relation(fields: [customerId], references: [id])
  customerId    Int
  orderItems    OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(0)
  subTotal  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product  @relation(fields: [productId], references: [id])
  productId Int      // Corrigido de snackId para productId para bater com o modelo Product
}